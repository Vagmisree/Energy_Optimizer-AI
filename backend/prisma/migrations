CREATE EXTENSION IF NOT EXISTS "pgcrypto";

CREATE TABLE "User" (
  "id" TEXT NOT NULL,
  "name" TEXT NOT NULL,
  "email" TEXT NOT NULL,
  "passwordHash" TEXT,
  "createdAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
  "updatedAt" TIMESTAMP(3) NOT NULL,
  "planType" TEXT NOT NULL DEFAULT 'FREE',
  "homeSize" INTEGER NOT NULL DEFAULT 2,
  "city" TEXT NOT NULL DEFAULT 'Hyderabad',
  "tariffRatePeak" DOUBLE PRECISION NOT NULL DEFAULT 10.5,
  "tariffRateOffPeak" DOUBLE PRECISION NOT NULL DEFAULT 6.2,
  "monthlyBudget" DOUBLE PRECISION NOT NULL DEFAULT 3000,
  CONSTRAINT "User_pkey" PRIMARY KEY ("id")
);

CREATE UNIQUE INDEX "User_email_key" ON "User"("email");

CREATE TABLE "Appliance" (
  "id" TEXT NOT NULL,
  "userId" TEXT NOT NULL,
  "name" TEXT NOT NULL,
  "category" TEXT NOT NULL,
  "wattage" INTEGER NOT NULL,
  "dailyHours" DOUBLE PRECISION NOT NULL,
  "isSmartEnabled" BOOLEAN NOT NULL DEFAULT false,
  "priority" INTEGER NOT NULL DEFAULT 3,
  "createdAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
  "updatedAt" TIMESTAMP(3) NOT NULL,
  CONSTRAINT "Appliance_pkey" PRIMARY KEY ("id")
);

CREATE TABLE "EnergyReading" (
  "id" TEXT NOT NULL,
  "userId" TEXT NOT NULL,
  "timestamp" TIMESTAMP(3) NOT NULL,
  "totalUsageKwh" DOUBLE PRECISION NOT NULL,
  "totalBill" DOUBLE PRECISION NOT NULL,
  "peakUsageKwh" DOUBLE PRECISION NOT NULL,
  "offPeakUsageKwh" DOUBLE PRECISION NOT NULL,
  "carbonKg" DOUBLE PRECISION NOT NULL,
  "source" TEXT NOT NULL DEFAULT 'manual',
  "createdAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
  CONSTRAINT "EnergyReading_pkey" PRIMARY KEY ("id")
);

CREATE TABLE "ApplianceUsage" (
  "id" TEXT NOT NULL,
  "userId" TEXT NOT NULL,
  "applianceId" TEXT NOT NULL,
  "timestamp" TIMESTAMP(3) NOT NULL,
  "usageKwh" DOUBLE PRECISION NOT NULL,
  "cost" DOUBLE PRECISION NOT NULL,
  "status" TEXT NOT NULL,
  "createdAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
  CONSTRAINT "ApplianceUsage_pkey" PRIMARY KEY ("id")
);

CREATE TABLE "Forecast" (
  "id" TEXT NOT NULL,
  "userId" TEXT NOT NULL,
  "month" TEXT NOT NULL,
  "predictedUsageKwh" DOUBLE PRECISION NOT NULL,
  "predictedBill" DOUBLE PRECISION NOT NULL,
  "confidenceScore" DOUBLE PRECISION NOT NULL,
  "explanation" TEXT NOT NULL,
  "createdAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
  CONSTRAINT "Forecast_pkey" PRIMARY KEY ("id")
);

CREATE TABLE "Recommendation" (
  "id" TEXT NOT NULL,
  "userId" TEXT NOT NULL,
  "title" TEXT NOT NULL,
  "description" TEXT NOT NULL,
  "impactScore" INTEGER NOT NULL,
  "estimatedSavings" DOUBLE PRECISION NOT NULL,
  "priority" INTEGER NOT NULL DEFAULT 2,
  "category" TEXT NOT NULL,
  "isApplied" BOOLEAN NOT NULL DEFAULT false,
  "createdAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
  "updatedAt" TIMESTAMP(3) NOT NULL,
  CONSTRAINT "Recommendation_pkey" PRIMARY KEY ("id")
);

CREATE TABLE "OptimizationAction" (
  "id" TEXT NOT NULL,
  "userId" TEXT NOT NULL,
  "actionType" TEXT NOT NULL,
  "applianceName" TEXT NOT NULL,
  "oldValue" TEXT NOT NULL,
  "newValue" TEXT NOT NULL,
  "estimatedSavings" DOUBLE PRECISION NOT NULL,
  "timestamp" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
  "createdAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
  CONSTRAINT "OptimizationAction_pkey" PRIMARY KEY ("id")
);

CREATE TABLE "Alert" (
  "id" TEXT NOT NULL,
  "userId" TEXT NOT NULL,
  "severity" TEXT NOT NULL,
  "title" TEXT NOT NULL,
  "message" TEXT NOT NULL,
  "isRead" BOOLEAN NOT NULL DEFAULT false,
  "createdAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
  CONSTRAINT "Alert_pkey" PRIMARY KEY ("id")
);

CREATE TABLE "AuditLog" (
  "id" TEXT NOT NULL,
  "userId" TEXT NOT NULL,
  "eventType" TEXT NOT NULL,
  "payload" JSONB NOT NULL,
  "createdAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
  CONSTRAINT "AuditLog_pkey" PRIMARY KEY ("id")
);

ALTER TABLE "Appliance"
ADD CONSTRAINT "Appliance_userId_fkey"
FOREIGN KEY ("userId") REFERENCES "User"("id") ON DELETE CASCADE ON UPDATE CASCADE;

